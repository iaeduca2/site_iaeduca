---
import "@fontsource/inter/400.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/700.css";
import "../styles/global.css";

interface Props {
	title?: string;
}

const { title = "Hub IA Educa" } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="Hub curado de ferramentas de Inteligência Artificial para apoiar educadores e alunos SENAI em suas rotinas pedagógicas."
		/>
		<title>{title}</title>
	</head>
	<body class="flex min-h-screen flex-col">
		<header class="border-b border-border bg-surface">
			<div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-4 md:px-6">
				<a href="/" class="flex items-center gap-3">
					<img
						src="/images/brand/logo-ia-educa.png"
						alt="Projeto IA Educa"
						class="h-10 w-auto md:h-12"
					/>
				</a>
				<nav aria-label="Navegação principal">
					<a
						href="/"
						class="text-sm font-semibold text-primary hover:text-primary-hover"
					>
						Ferramentas
					</a>
				</nav>
			</div>
		</header>

		<main class="flex-1">
			<slot />
		</main>

		<footer class="bg-primary text-white">
			<div
				class="mx-auto flex max-w-6xl flex-col items-center gap-6 px-4 py-10 text-center md:flex-row md:justify-between md:text-left"
			>
				<img
					src="/images/brand/logo-ia-educa-negativo.png"
					alt="Projeto IA Educa"
					class="h-10 w-auto"
				/>
				<p class="text-sm text-white/80">
					Hub curado de ferramentas de Inteligência Artificial para educadores e
					alunos SENAI.
				</p>
				<img
					src="/images/brand/logo-centro-inovacao-negativo.png"
					alt="Centro de Inovação da Educação Profissional SENAI"
					class="h-10 w-auto"
				/>
			</div>
		</footer>
	</body>
</html>
